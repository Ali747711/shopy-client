  "about": {
    "title": "Shopy \uc18c\uac1c",
    "headline": "\uc6d0\ud558\ub294 \uac83\uc744 \uc774\ud574\ud558\ub294 \ucfe0\ud551",
    "intro": "Shopy\ub294 AI \uae30\ubc18 \uc2a4\ud1a0\uc5b4\uc785\ub2c8\ub2e4. \ud544\ud130\ub97c \ub4a4\uc9c0\ub294 \ub300\uc2e0, \uc6d0\ud558\ub294 \uac83\uc744 \uc790\uc5f0\uc5b4\ub85c \uc124\uba85\ud558\uba74 \uc2e4\uc81c \uce74\ud0c8\ub85c\uadf8\uc5d0\uc11c \ucc3e\uc544\ub4dc\ub9bd\ub2c8\ub2e4.",
    "feature1Title": "\uac80\uc0c9\ud558\uc9c0 \ub9d0\uace0, \uc124\uba85\ud558\uc138\uc694",
    "feature1Desc": "\ub05d\uc5c6\ub294 \ud544\ud130\ub97c \uac74\ub108\ub6f0\uc138\uc694. \uc5b4\uc2dc\uc2a4\ud134\ud2b8\uc5d0\uac8c \ub9d0\ud558\uba74 \ub300\uc2e0 \uac80\uc0c9\ud574 \ub4dc\ub9bd\ub2c8\ub2e4.",
    "feature2Title": "\uc2e4\uc81c \uce74\ud0c8\ub85c\uadf8 \uae30\ubc18 \ucd94\ucc9c",
    "feature2Desc": "\ubaa8\ub4e0 \ucd94\ucc9c\uc740 \uc2e4\uc81c \uce74\ud0c8\ub85c\uadf8\uc5d0\uc11c \uac00\uc838\uc635\ub2c8\ub2e4 \u2014 \uac00\uc0c1\uc758 \uc0c1\ud488\uc774\ub098 \ud5db\ub41c \uc815\ubcf4\uac00 \uc5c6\uc2b5\ub2c8\ub2e4.",
    "feature3Title": "\uc548\uc804\ud55c \uacb0\uc81c",
    "feature3Desc": "Stripe \uce74\ub4dc \uacb0\uc81c\uc640 \ub300\uae08 \uc0c1\ud658 \ubd88, \uba85\ud655\ud55c \uc8fc\ubb38 \ubc0f \uacb0\uc81c \uc0c1\ud0dc \ud655\uc778.",
    "feature4Title": "\ub2e4\uc911 \ud1b5\ud654",
    "feature4Desc": "USD \uae30\ubcf8\uc73c\ub85c EUR, GBP, KWD, UZS\ub85c \uc2e4\uc2dc\uac04 \ud658\uc728 \uc801\uc6a9.",
    "howItWorks": "\uc774\uc6a9 \ubc29\ubc95",
    "step1Title": "\uc124\uba85\ud558\uae30",
    "step1Desc": "\uc5b4\uc2dc\uc2a4\ud134\ud2b8\ub97c \uc5f4\uace0 \uc6d0\ud558\ub294 \uac83\uc744 \ub9d0\ud574 \uc8fc\uc138\uc694 \u2014 \uc608\uc0b0, \uc6a9\ub3c4, \ubd84\uc704\uae30 \ub4f1.",
    "step2Title": "\uc138\ubd80 \uc870\uc815",
    "step2Desc": "\uc801\uc808\ud55c \ucd94\uac00 \uc9c8\ubb38\uc744 \ud1b5\ud574 \uc2e4\uc81c \uce74\ud0c8\ub85c\uadf8\uc5d0\uc11c \uacb0\uacfc\ub97c \uc88b\ud600\ub098\uac11\ub2c8\ub2e4.",
    "step3Title": "\uacb0\uc815\ud558\uae30",
    "step3Desc": "\uc2e4\uc81c \uce74\ud0c8\ub85c\uadf8 \uae30\ubc18 \ucd94\ucc9c\uc5d0\uc11c \uc120\ud0dd\ud558\uace0 \ubc14\ub85c \uc0c1\ud488 \ud398\uc774\uc9c0\ub098 \uacb0\uc81c\ub85c \uc774\ub3d9\ud558\uc138\uc694.",
    "faq": "\uc790\uc8fc \ubb3b\ub294 \uc9c8\ubb38",
    "faq1Q": "\uc77c\ubc18 \uac80\uc0c9\uacfc \uc5b4\ub5bb\uac8c \ub2e4\ub978\uac00\uc694?",
    "faq1A": "\ud0a4\uc6cc\ub4dc \uac80\uc0c9\uc740 \ub2e8\uc5b4\ub97c \ub9e4\uce6d\ud569\ub2c8\ub2e4. Shopy\ub294 \uc758\ub3c4\ub97c \ud30c\uc545\ud569\ub2c8\ub2e4 \u2014 \u201c\ube44 \uc624\ub294 \ub0a0\uc528\uc5d0 \uc785\uc744 \uac00\ubcbc\uc6b4 \uc7ac\ud0b7 8\ub9cc\uc6d0 \uc774\ud558\u201d\ub97c \uce74\ud14c\uace0\ub9ac, \uac00\uaca9 \uc0c1\ud55c, \uc18d\uc131\uc73c\ub85c \uc774\ud574\ud558\uace0 \ubca1\ud130 \uc720\uc0ac\ub3c4\uc640 \uad6c\uc870\ud654\ub41c \ud544\ud130\ub97c \uacb0\ud569\ud569\ub2c8\ub2e4.",
    "faq2Q": "\uc5b4\uc2dc\uc2a4\ud134\ud2b8\uac00 \uc5c6\ub294 \uc0c1\ud488\uc744 \ub9cc\ub4e4\uc5b4\ub0b4\ub098\uc694?",
    "faq2A": "\uc544\ub2c8\uc694. \ubaa8\ub4e0 \ub2f5\ubcc0\uc740 RAG(\uac80\uc0c9 \uc99d\uac15 \uc0dd\uc131)\ub97c \ud1b5\ud574 \uc2e4\uc81c \uce74\ud0c8\ub85c\uadf8\uc5d0 \uae30\ubc18\ud569\ub2c8\ub2e4 \u2014 \uc2e4\uc81c\ub85c \uac80\uc0c9\ub41c \uc0c1\ud488\ub9cc \ucd94\ucc9c\ud569\ub2c8\ub2e4.",
    "faq3Q": "\ud0d0\uc0c9\ud558\ub824\uba74 \uacc4\uc815\uc774 \ud544\uc694\ud55c\uac00\uc694?",
    "faq3A": "\uc544\ub2c8\uc694. \ucc44\ud305, \uac80\uc0c9, \uc804\uccb4 \uce74\ud0c8\ub85c\uadf8 \ud0d0\uc0c9\uc744 \ube44\ud68c\uc6d0\uc73c\ub85c \uc774\uc6a9\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uacc4\uc815\uc740 \uc8fc\ubb38\uacfc \ub9de\ucda4 \ucd94\ucc9c\uc5d0\ub9cc \ud544\uc694\ud569\ub2c8\ub2e4.",
    "faq4Q": "\uc5b4\ub5a4 \uacb0\uc81c \ubc29\ubc95\uc744 \uc9c0\uc6d0\ud558\ub098\uc694?",
    "faq4A": "Stripe \uce74\ub4dc \uacb0\uc81c\uc640 \ub300\uae08 \uc0c1\ud658 \ubd88\uc744 \uc9c0\uc6d0\ud569\ub2c8\ub2e4. \uc8fc\ubb38\uc740 \ubbf8\uacb0\uc81c\ubd80\ud130 \uacb0\uc81c \uc644\ub8cc, \uc2e4\ud328, \ud658\ubd88\uae4c\uc9c0 \uacb0\uc81c \uc0c1\ud0dc\ub97c \ucd94\uc801\ud569\ub2c8\ub2e4.",
    "faq5Q": "\uc5b4\ub5a4 \ud1b5\ud654\ub85c \ucfe0\ud551\ud560 \uc218 \uc788\ub098\uc694?",
    "faq5A": "USD\uac00 \uae30\ubcf8 \ud1b5\ud654\uc774\uba70 EUR, GBP, KWD, UZS\ub85c \uc2e4\uc2dc\uac04 \ud658\uc728\uc774 \uc801\uc6a9\ub429\ub2c8\ub2e4. \uac00\uaca9\uacfc \uc8fc\ubb38 \ucd1d\uc561\uc740 \uc120\ud0dd\ud55c \ud1b5\ud654\ub85c \ud45c\uc2dc\ub429\ub2c8\ub2e4.",
    "ctaTitle": "\uc9c1\uc811 \uccb4\ud5d8\ud574 \ubcf4\uc138\uc694!",
    "ctaDesc": "\uc6d0\ud558\ub294 \uac83\uc744 \uc124\uba85\ud558\uc138\uc694 \u2014 \uc5b4\uc2dc\uc2a4\ud134\ud2b8\uac00 \ub098\uba38\uc9c0\ub97c \ucc98\ub9ac\ud574 \ub4dc\ub9bd\ub2c8\ub2e4."
